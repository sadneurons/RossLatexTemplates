% ----------------------------------------------------------------
% Palette activation
% ----------------------------------------------------------------

\newcommand{\rp@activatepalette}{%
  \definecolor{rpPrimary}{HTML}{\csname rp@p@\rp@palette @P\endcsname}%
  \definecolor{rpSecondary}{HTML}{\csname rp@p@\rp@palette @S\endcsname}%
  \definecolor{rpAccent}{HTML}{\csname rp@p@\rp@palette @A\endcsname}%
  \definecolor{rpText}{HTML}{\csname rp@p@\rp@palette @T\endcsname}%
  \definecolor{rpTextLight}{HTML}{\csname rp@p@\rp@palette @TL\endcsname}%
  \definecolor{rpTextMuted}{HTML}{\csname rp@p@\rp@palette @TM\endcsname}%
  \definecolor{rpBg}{HTML}{\csname rp@p@\rp@palette @B\endcsname}%
  % Derived
  \colorlet{rpPrimaryLight}{rpPrimary!15!white}%
  \colorlet{rpPrimaryFaded}{rpPrimary!8!white}%
  \colorlet{rpAccentBg}{rpAccent!8!white}%
  \colorlet{rpAccentLight}{rpAccent!30!white}%
  \colorlet{rpRule}{rpTextMuted!30}%
}
\rp@activatepalette

\newcommand{\setrosspalette}[1]{\def\rp@palette{#1}\rp@activatepalette}

\endinput
