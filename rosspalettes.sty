% rosspalettes.sty
% Standalone palette system for non-beamer Ross document classes.
% Provides consistent colour theming across manuscripts, theses,
% CVs, posters, and any LaTeX document.
%
% Usage:
%   \usepackage[palette=lancet]{rosspalettes}
%
% Then use: \color{rpPrimary}, \color{rpAccent}, etc.
%
% Ross Dunne / Claude, 2026

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{rosspalettes}[2026/03/24 Palette system for Ross document classes]

\RequirePackage{xcolor}
\RequirePackage{pgfkeys}
\RequirePackage{pgfopts}
\RequirePackage{etoolbox}

% ----------------------------------------------------------------
% Options
% ----------------------------------------------------------------

\pgfkeys{
  /rosspalettes/.cd,
  palette/.store in=\rp@palette,
  palette=lancet,
}
\ProcessPgfOptions{/rosspalettes}

% ----------------------------------------------------------------
% Palette definitions (7-field: primary, secondary, accent,
%   text, textlight, textmuted, bg)
% ----------------------------------------------------------------

\newcommand{\rp@defpal}[8]{%
  \expandafter\def\csname rp@p@#1@P\endcsname{#2}%
  \expandafter\def\csname rp@p@#1@S\endcsname{#3}%
  \expandafter\def\csname rp@p@#1@A\endcsname{#4}%
  \expandafter\def\csname rp@p@#1@T\endcsname{#5}%
  \expandafter\def\csname rp@p@#1@TL\endcsname{#6}%
  \expandafter\def\csname rp@p@#1@TM\endcsname{#7}%
  \expandafter\def\csname rp@p@#1@B\endcsname{#8}%
}

