% rossbeamerbase.sty
% Shared infrastructure for Ross Beamer presentation classes.
% Not used directly — loaded by rossbeamercorporate.cls or
% rossbeamerscientific.cls.
%
% Provides: font engine, colour derivation, beamer setup,
% and all shared environments/commands.
%
% Ross Dunne / Claude, 2026

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{rossbeamerbase}[2026/03/24 Shared base for Ross Beamer classes]

% ----------------------------------------------------------------
% Flags (may be pre-defined by the loading class)
% ----------------------------------------------------------------

\@ifundefined{ifrb@nobar}{\newif\ifrb@nobar \rb@nobarfalse}{}
\@ifundefined{ifrb@nologo}{\newif\ifrb@nologo \rb@nologofalse}{}
\newif\ifrb@draft \rb@draftfalse
\def\rb@drafttext{DRAFT}

