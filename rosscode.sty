% rosscode.sty
% Standalone code-listing presets for R, Python, SPSS, SAS, MATLAB, LaTeX.
% Works with any document class; no -shell-escape needed.
%
% Options:
%   frame   — add a thin border around code blocks
%
% If rosspalettes is loaded, colours adapt to the active palette.
%
% Ross Dunne / Claude, 2026

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{rosscode}[2026/03/24 Code listing presets for R, Python, SPSS]

% ----------------------------------------------------------------
% Dependencies
% ----------------------------------------------------------------
\RequirePackage{xcolor}
\RequirePackage{listings}
\RequirePackage{etoolbox}
\RequirePackage{xkeyval}
\RequirePackage{tcolorbox}
\tcbuselibrary{listings,skins,breakable}

% ----------------------------------------------------------------
% Package option: frame
% ----------------------------------------------------------------
\newif\ifrc@frame
\rc@framefalse
\DeclareOptionX{frame}{\rc@frametrue}
\ProcessOptionsX\relax

% ----------------------------------------------------------------
% Default colours (overridden below if rosspalettes is loaded)
% ----------------------------------------------------------------
\definecolor{rc@keyword}{HTML}{1A5FB4}    % blue
\definecolor{rc@string}{HTML}{2E7D32}     % green
\definecolor{rc@comment}{HTML}{808080}    % grey
\definecolor{rc@number}{HTML}{A0522D}     % sienna
\definecolor{rc@funcname}{HTML}{7B3F9E}   % purple
\definecolor{rc@codebg}{HTML}{F7F7F7}    % near-white
\definecolor{rc@codeborder}{HTML}{CCCCCC} % light grey
\definecolor{rc@outputbg}{HTML}{EDEDED}   % grey for console output
\definecolor{rc@outputfg}{HTML}{1C1C1C}   % dark text for output
\definecolor{rcBase}{HTML}{1C1C1C}       % base text

% ----------------------------------------------------------------
% Adapt colours when rosspalettes is available
% ----------------------------------------------------------------
\AtBeginDocument{%
  \@ifpackageloaded{rosspalettes}{%
    \colorlet{rc@keyword}{rpAccent}%
    \colorlet{rc@string}{rpSecondary!70!black}%
    \colorlet{rc@comment}{rpTextMuted}%
    \colorlet{rc@funcname}{rpPrimary!70!rpAccent}%
    \colorlet{rc@codebg}{rpBg}%
    \colorlet{rc@codeborder}{rpRule}%
    \colorlet{rc@outputbg}{rpPrimaryFaded}%
    \colorlet{rcBase}{rpText}%
  }{}%
}

% ----------------------------------------------------------------
% Base listing style
% ----------------------------------------------------------------
\lstdefinestyle{rcBase}{%
  basicstyle=\ttfamily\small\color{rcBase},
  keywordstyle=\color{rc@keyword}\bfseries,
  stringstyle=\color{rc@string},
  commentstyle=\color{rc@comment}\itshape,
  numberstyle=\tiny\color{rc@comment},
  identifierstyle=\color{rcBase},
  showstringspaces=false,
  breaklines=true,
  breakatwhitespace=false,
  tabsize=4,
  keepspaces=true,
  columns=flexible,
  extendedchars=true,
  literate={*}{{\char42}}1,
  escapeinside={(*@}{@*)},
}

% ----------------------------------------------------------------
% Language-specific styles
% ----------------------------------------------------------------

% --- R ---
\lstdefinestyle{rcR}{%
  style=rcBase,
  language=R,
  morekeywords={library,require,function,if,else,for,while,repeat,
    in,next,break,return,TRUE,FALSE,NULL,NA,NA_real_,NA_complex_,
    NA_integer_,NA_character_,Inf,NaN,data.frame,tibble,mutate,
    filter,select,summarise,group_by,pipe,ggplot,aes,geom_point,
    geom_line,geom_bar,lm,glm,t.test,aov,cor.test},
  sensitive=true,
  morecomment=[l]{\#},
  morestring=[b]",
  morestring=[b]',
}

% --- Python ---
\lstdefinestyle{rcPython}{%
  style=rcBase,
  language=Python,
  morekeywords={self,True,False,None,as,with,yield,async,await,
    lambda,nonlocal,assert,import,from,class,def,return,if,elif,
    else,for,while,try,except,finally,raise,pass,break,continue,
    print,range,len,list,dict,tuple,set,int,float,str,bool,
    isinstance,enumerate,zip,map,super},
  sensitive=true,
  morecomment=[l]{\#},
  morecomment=[s]{"""}{"""},
  morecomment=[s]{'''}{'''},
  morestring=[b]",
  morestring=[b]',
}

% --- SPSS ---
\lstdefinestyle{rcSPSS}{%
  style=rcBase,
  morekeywords={DATA,LIST,BEGIN,END,GET,FILE,SAVE,OUTFILE,COMPUTE,
    RECODE,IF,DO,REPEAT,LOOP,FREQUENCIES,DESCRIPTIVES,CROSSTABS,
    MEANS,CORRELATIONS,REGRESSION,ANOVA,T-TEST,NPAR,TESTS,
    VARIABLE,LABELS,VALUE,MISSING,VALUES,EXECUTE,DATASET,
    ACTIVATE,SELECT,CASES,SORT,BY,SPLIT,WEIGHT,FILTER,
    TEMPORARY,FORMATS,ADD,FILES,MATCH,AGGREGATE,BREAK},
  sensitive=false,
  morecomment=[l]{*},
  morecomment=[s]{/*}{*/},
  morestring=[b]",
  morestring=[b]',
}

% --- SAS ---
\lstdefinestyle{rcSAS}{%
  style=rcBase,
  morekeywords={data,set,input,cards,run,proc,quit,if,then,else,
    do,end,output,drop,keep,rename,where,merge,by,retain,
    length,format,informat,array,macro,mend,let,put,
    means,freq,print,sort,transpose,sql,logistic,reg,
    glm,mixed,sgplot,sgpanel,ods,title,footnote,libname},
  sensitive=false,
  morecomment=[l]{*},
  morecomment=[s]{/*}{*/},
  morestring=[b]",
  morestring=[b]',
}

% --- MATLAB ---
\lstdefinestyle{rcMATLAB}{%
  style=rcBase,
  language=Matlab,
  morekeywords={function,end,if,elseif,else,for,while,switch,case,
    otherwise,try,catch,return,break,continue,global,persistent,
    classdef,properties,methods,events,true,false,
    figure,plot,xlabel,ylabel,title,legend,hold,subplot,
    fprintf,disp,zeros,ones,eye,linspace,rand,randn},
  sensitive=true,
  morecomment=[l]{\%},
  morecomment=[s]{\%\{}{\%\}},
  morestring=[b]',
  morestring=[b]",
}

% --- LaTeX ---
\lstdefinestyle{rcLaTeX}{%
  style=rcBase,
  language=[LaTeX]TeX,
  morekeywords={documentclass,usepackage,begin,end,newcommand,
    renewcommand,setlength,includegraphics,caption,label,ref,
    cite,bibliography,bibliographystyle,tableofcontents,
    section,subsection,subsubsection,chapter,part,
    textbf,textit,emph,footnote,item,title,author,date,
    maketitle,input,include,RequirePackage,ProvidesPackage},
  sensitive=true,
  texcsstyle=*\color{rc@keyword}\bfseries,
  morecomment=[l]{\%},
  morestring=[b]",
}

% ----------------------------------------------------------------
% Resolve style name from language argument
% ----------------------------------------------------------------
\newcommand{\rc@getstyle}[1]{%
  % Default to rcBase if no language given
  \def\rc@resolved{rcBase}%
  \ifstrempty{#1}{}{%
    \def\rc@resolved{rc#1}%
  }%
}

% ----------------------------------------------------------------
% \codeinline[lang]{code} — inline code snippet
% ----------------------------------------------------------------
\newcommand{\codeinline}[2][]{%
  \rc@getstyle{#1}%
  \ifstrempty{#1}{%
    \lstinline[style=rcBase]|#2|%
  }{%
    \begingroup\edef\rc@tmp{\endgroup
      \noexpand\lstinline[style=\rc@resolved]|#2|}%
    \rc@tmp
  }%
}

% ----------------------------------------------------------------
% codechunk environment — code block with optional language label
%   \begin{codechunk}[R] ... \end{codechunk}
% ----------------------------------------------------------------

% Helper: tcolorbox style for code blocks (reused by \codefile)
\newtcolorbox[auto counter]{rc@codeblock}[2][]{%
  enhanced,
  breakable,
  colback=rc@codebg,
  colframe=\ifrc@frame rc@codeborder\else rc@codebg\fi,
  boxrule=\ifrc@frame 0.4pt\else 0pt\fi,
  arc=2pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt,
  fontupper=\ttfamily\small,
  before upper={\parindent0pt},
  overlay={%
    \ifstrempty{#2}{}{%
      \node[anchor=north east,
            font=\sffamily\scriptsize\bfseries,
            text=rc@comment,
            inner sep=2pt]
        at (frame.north east) {#2};%
    }%
  },
  #1
}

% The codechunk environment uses tcolorbox's listing integration
% so that the verbatim scanning and the box work together.
\newtcblisting{codechunk}[1][]{%
  enhanced,
  breakable,
  colback=rc@codebg,
  colframe=\ifrc@frame rc@codeborder\else rc@codebg\fi,
  boxrule=\ifrc@frame 0.4pt\else 0pt\fi,
  arc=2pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt,
  overlay={%
    \ifstrempty{#1}{}{%
      \node[anchor=north east,
            font=\sffamily\scriptsize\bfseries,
            text=rc@comment,
            inner sep=2pt]
        at (frame.north east) {#1};%
    }%
  },
  listing only,
  listing options={%
    style=\ifstrempty{#1}{rcBase}{rc#1},
    numbers=left,
    numbersep=8pt,
    xleftmargin=14pt,
    aboveskip=0pt,
    belowskip=0pt,
    resetmargins=true,
    nolol=true,
  },
}

% ----------------------------------------------------------------
% codeoutput environment — grey box for console / program output
% ----------------------------------------------------------------
\newtcblisting{codeoutput}[1][]{%
  enhanced,
  breakable,
  colback=rc@outputbg,
  colframe=\ifrc@frame rc@codeborder\else rc@outputbg\fi,
  boxrule=\ifrc@frame 0.4pt\else 0pt\fi,
  arc=2pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt,
  listing only,
  listing options={%
    basicstyle=\ttfamily\small\color{rc@outputfg},
    numbers=none,
    aboveskip=0pt,
    belowskip=0pt,
    resetmargins=true,
    nolol=true,
  },
  overlay={%
    \node[anchor=north east,
          font=\sffamily\scriptsize\bfseries,
          text=rc@comment,
          inner sep=2pt]
      at (frame.north east) {Output};%
  },
  #1
}

% ----------------------------------------------------------------
% \codefile[lang]{filepath} — include external code file
% ----------------------------------------------------------------
\newcommand{\codefile}[2][]{%
  \rc@getstyle{#1}%
  \begin{rc@codeblock}{#1}%
  \begingroup\edef\rc@tmp{\endgroup
    \noexpand\lstinputlisting[%
      style=\rc@resolved,
      numbers=left,
      numbersep=8pt,
      xleftmargin=14pt,
      aboveskip=0pt,
      belowskip=0pt,
      resetmargins=true,
      nolol=true,
    ]{\noexpand#2}%
  }\rc@tmp
  \end{rc@codeblock}%
}

\endinput
